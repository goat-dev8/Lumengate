# Lumengate root environment template (local CLI / scripts only)
# Copy to .env and fill — NEVER commit .env

STELLAR_NETWORK_NAME=testnet
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Deployer + admin (testnet only)
DEPLOYER_SECRET_KEY=
CONTRACT_ADMIN_PUBLIC_KEY=
CONTRACT_ADMIN_SECRET_KEY=

# Ed25519 eligibility issuer
ISSUER_ID=2
ISSUER_ED25519_SECRET=
ISSUER_STELLAR_PUBLIC_KEY=
ISSUER_ED25519_PUBKEY_BYTES64=

# Contract IDs (see deployments.json)
ISSUER_REGISTRY_ID=
CREDENTIAL_REGISTRY_ID=
POLICY_VERIFIER_ID=
RWA_ADAPTER_ID=
COMPLIANCE_SAC_ADMIN_ID=
POLICY_ID=1
POLICY_ID_2=2

# Issuer API
REVOKE_API_KEY=
ISSUER_SERVICE_PORT=3001
CORS_ORIGIN=http://localhost:5173

# Regression wallets (testnet)
ELIGIBLE_WALLET_PUBLIC_KEY=
ELIGIBLE_WALLET_SECRET=

# Confidential Token (Stellar Developer Preview — testnet; see deployments.json)
CONFIDENTIAL_TOKEN_ID=
CONFIDENTIAL_VERIFIER_ID=
CONFIDENTIAL_AUDITOR_ID=
CONFIDENTIAL_POLICY_ID=
CONFIDENTIAL_UNDERLYING_ID=
